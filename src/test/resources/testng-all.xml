<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Full Automation Suite" verbose="2" parallel="classes" thread-count="3">

    <test name="UI Tests">
        <classes>
            <class name="com.ui.LoginTest"/>
            <class name="com.ui.AddToCartTest"/>
            <class name="com.ui.CheckoutTest"/>
        </classes>
    </test>

    <test name="API Tests">
        <classes>
            <class name="com.api.GetUserTest"/>
            <class name="com.api.CreateUserTest"/>
            <class name="com.api.DeleteUserTest"/>
        </classes>
    </test>

    <test name="Combined UI + API Tests">
        <classes>
            <class name="com.combined.UiApiCombinedTest"/>
        </classes>
    </test>

</suite>
